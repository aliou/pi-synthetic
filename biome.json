{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "plugins": [
    "./node_modules/@aliou/biome-plugins/plugins/no-buried-await.grit",
    "./node_modules/@aliou/biome-plugins/plugins/no-emojis.grit",
    "./node_modules/@aliou/biome-plugins/plugins/no-empty-catch.grit",
    "./node_modules/@aliou/biome-plugins/plugins/no-homedir.grit",
    "./node_modules/@aliou/biome-plugins/plugins/no-inline-imports.grit",
    "./node_modules/@aliou/biome-plugins/plugins/no-inner-types.grit",
    "./node_modules/@aliou/biome-plugins/plugins/no-is-record.grit",
    "./node_modules/@aliou/biome-plugins/plugins/no-js-import-extension.grit",
    "./node_modules/@aliou/biome-plugins/plugins/no-ts-import-extension.grit",
    "./node_modules/@aliou/biome-plugins/plugins/pi-no-node-exec.grit"
  ],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**/*.ts", "**/*.json"],
    "ignoreUnknown": true
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  }
}
